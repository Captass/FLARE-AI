# ===============================
# Chatbot Facebook - Variables
# ===============================

# Infra n8n
TIMEZONE=Indian/Antananarivo
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=https://your-n8n-domain.example/
N8N_ENCRYPTION_KEY=change-this-with-a-long-random-secret

# PostgreSQL pour n8n
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-this-db-password

# Meta / Facebook Messenger
META_VERIFY_TOKEN=change-this-verify-token
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_GRAPH_VERSION=vXX.X

# IA - endpoint compatible chat completions
AI_COMPLETION_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Google Sheets
GSHEET_ID=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optionnel - futur pont FLARE AI
FLARE_AI_WEBHOOK_URL=
FLARE_AI_API_KEY=

