# ============================================================
# FLARE AI OS - Backend production example
# Copy to .env only on the production deployment target.
# ============================================================

APP_ENV=production
HOST=0.0.0.0
PORT=8080

FRONTEND_URL=https://flareai.ramsflare.com
BACKEND_URL=https://flare-backend-<project>.run.app

LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

DATABASE_URL=postgresql://<user>:<password>@<host>/<database>

META_APP_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=flare-production-verify-token
META_APP_SECRET=
META_PAGE_ID=
META_GRAPH_VERSION=v25.0

MESSENGER_DIRECT_URL=https://messenger-direct-<project>.run.app
MESSENGER_DIRECT_DASHBOARD_KEY=

GOOGLE_SERVICE_ACCOUNT_JSON=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=RAM'S FLARE
