# ============================================================
# FLARE AI OS - Backend local development example
# Copy this file to .env for local work.
# Dedicated staging / production examples exist next to this file.
# ============================================================

APP_ENV=development

HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

DATABASE_URL=sqlite:///./flare_ai_os.db

META_APP_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=flare-dev-verify-token
META_APP_SECRET=
META_PAGE_ID=
META_GRAPH_VERSION=v25.0

MESSENGER_DIRECT_URL=http://localhost:8081
MESSENGER_DIRECT_DASHBOARD_KEY=

GOOGLE_SERVICE_ACCOUNT_JSON=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=RAM'S FLARE
