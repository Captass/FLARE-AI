rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Default: Deny all access to prevent any accidental openings
    match /{document=**} {
      allow read, write: if false;
    }

    // User can read and write their own subscription data
    match /user_subscriptions/{userId} {
      allow read, update: if isOwner(userId);
      // Deny creation or deletion from client-side
      allow create, delete: if false;
    }

    // User can read and write their own core memory facts
    match /core_memory_facts/{factId} {
      allow read, write: if isOwner(resource.data.user_id);
    }
    
    // User can read and write their own system settings (like preferences)
    match /system_settings/{settingId} {
        allow read, write: if isOwner(resource.data.user_id);
    }

    // User can read, write, and delete their own conversations and messages
    match /conversations/{conversationId} {
      allow read, write, delete: if isOwner(resource.data.user_id);
      match /messages/{messageId} {
        allow read, write, delete: if isOwner(get(/databases/$(database)/documents/conversations/$(conversationId)).data.user_id);
      }
    }
    
    // Usage ledger should NOT be client-writable to prevent tampering
    match /usage_ledger/{ledgerId} {
      allow read, create, update, delete: if false;
    }
  }
}