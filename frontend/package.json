{
  "name": "flare-ai-os-frontend",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deploy": "npm run build && npx firebase-tools deploy --only hosting",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:apk": "npm run android:apk:debug",
    "android:apk:debug": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:apk:release": "npm run android:sync && cd android && gradlew.bat assembleRelease",
    "desktop:dev": "npx tauri dev --config ../desktop/tauri/src-tauri/tauri.conf.json",
    "desktop:build": "npx tauri build --config ../desktop/tauri/src-tauri/tauri.conf.json",
    "desktop:build:windows": "npx tauri build --target x86_64-pc-windows-msvc --config ../desktop/tauri/src-tauri/tauri.conf.json"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.2",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/cli": "^7.6.2",
    "@capacitor/core": "^7.6.2",
    "@headlessui/react": "^2.2.9",
    "@react-three/drei": "^9.120.3",
    "@react-three/fiber": "^8.17.14",
    "@splinetool/react-spline": "^4.1.0",
    "@tauri-apps/api": "^1.6.0",
    "@types/three": "^0.172.0",
    "clsx": "^2.1.1",
    "firebase": "^12.10.0",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.379.0",
    "mammoth": "^1.12.0",
    "next": "14.2.3",
    "playwright": "^1.58.2",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^5.6.0",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.172.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.6.3",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "firebase-tools": "^13.8.0",
    "postcss": "^8",
    "tailwindcss": "3.4.1",
    "typescript": "^5.9.3"
  }
}
