# Frontend FLARE AI - Staging example

NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_API_URL=https://flare-backend-staging-<project>.run.app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Native runtime callbacks (Windows Tauri + Android only)
NEXT_PUBLIC_WINDOWS_CALLBACK_URL=
NEXT_PUBLIC_ANDROID_CALLBACK_URL=

# Optional API overrides for native runtimes
NEXT_PUBLIC_API_URL_DESKTOP=
NEXT_PUBLIC_API_URL_ANDROID=

# Download endpoints used by /download
NEXT_PUBLIC_WINDOWS_DOWNLOAD_URL=
NEXT_PUBLIC_ANDROID_DOWNLOAD_URL=
NEXT_PUBLIC_WEB_APP_URL=/app?auth=signup
